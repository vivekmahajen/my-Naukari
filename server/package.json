{
  "name": "naukri-plus-server",
  "version": "1.0.0",
  "description": "Backend API for Naukri+ — Express + PostgreSQL + JWT auth",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/migrate.js",
    "seed": "node src/seed.js",
    "import:employers": "node src/import_employers.js",
    "setup": "npm run migrate && npm run seed && npm run import:employers",
    "test": "node test/smoke.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  }
}
